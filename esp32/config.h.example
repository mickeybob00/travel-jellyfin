#ifndef CONFIG_H
#define CONFIG_H

// ============================================================
// Travel Jellyfin CYD — Configuration
// ESP32-035 (3.5" resistive touch, XPT2046, ST7796)
// Portrait mode: 320 wide x 480 tall
// ============================================================
// Copy this file to config.h and fill in your values.

// ---- WiFi ----
#define WIFI_SSID_HOTSPOT   "Travel-Jellyfin"
#define WIFI_PASS_HOTSPOT   "YOUR_HOTSPOT_PASSWORD"
#define WIFI_SSID_HOME      "YOUR_HOME_WIFI_SSID"
#define WIFI_PASS_HOME      "YOUR_HOME_WIFI_PASSWORD"

// ---- Pi API ----
#define PI_API_HOST_HOTSPOT "10.42.0.1"
#define PI_API_HOST_HOME    "192.168.1.145"
#define PI_API_PORT         9090
#define PI_API_KEY          "YOUR_API_KEY"

// ---- Polling ----
#define POLL_INTERVAL_MS    3000

// ---- Touch calibration (XPT2046 resistive) ----
#define TOUCH_CAL_LEFT      300
#define TOUCH_CAL_RIGHT     3700
#define TOUCH_CAL_TOP       300
#define TOUCH_CAL_BOT       3700
#define TOUCH_CAL_FLAG      0
#define INVERT_TOUCH_X      1
#define INVERT_TOUCH_Y      1

// ---- RGB LED (active-low) ----
#define LED_R   4
#define LED_G   17
#define LED_B   16

// ---- Backlight ----
#define BL_PIN  27
#define BACKLIGHT_DIM_MS      30000
#define BACKLIGHT_DIM_LEVEL   80

// ---- Display rotation ----
#define TFT_ROTATION 0

#endif // CONFIG_H
